    "mermaid",
    "obsidian",
    "canvas",
    "graph"
  ],
  "license": "MIT",
  "dependencies": {
    "@mermaid-js/parser": "^0.6.2",
    "dagre": "^0.8.5",
    "nanoid": "^5.1.6",
    "prompts": "^2.4.2"
  }
}
